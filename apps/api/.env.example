PORT=3002
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST/sendam?sslmode=require
# Comma-separated origins allowed to call the REST API (admin + landing apps).
# Required in production; when empty in dev, all origins are allowed.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# 64-char hex (32 bytes). Generate your own — never reuse this placeholder.
# Used for aes-256-gcm encryption of wallet secret keys.
# openssl rand -hex 32
ENCRYPTION_KEY=
# Admin dashboard auth. ADMIN_PASSWORD is the login password; JWT_SECRET signs
# session tokens (use a long random value: openssl rand -hex 32). Both are
# required — the API will not start without them.
ADMIN_PASSWORD=
JWT_SECRET=
# Optional: admin session lifetime in hours (default 12).
ADMIN_SESSION_TTL_HOURS=12
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token
# Meta App Secret — verifies the X-Hub-Signature-256 header on webhook POSTs.
# Required in production; without it, forged webhook events are rejected.
WHATSAPP_APP_SECRET=
# Per-user transfer guardrails (XLM). Defaults: 1000 / 5000 / 50.
MAX_SEND_AMOUNT=1000
DAILY_SEND_LIMIT=5000
MAX_SENDS_PER_DAY=50
# Request rate limits (PostgreSQL-backed, shared across instances).
# REST API: max requests per IP per window. WhatsApp bot: max messages per
# sender per window.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
BOT_RATE_WINDOW_SEC=60
BOT_RATE_MAX=20
REDIS_URL=
UPSTASH_REDIS_URL=
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# The REST wallet API (/api/wallet/*) is unauthenticated — the phone number in
# the request body is the only identity. It's disabled in production unless you
# set this to "true". Outside production it defaults to enabled for local tests.
ENABLE_WALLET_REST_API=false

# Wallet-as-a-Service. Self-custody on Lisk by default (keys generated and
# encrypted in this process, see wallet/lisk.adapter.js and
# services/crypto.service.js) — no per-wallet vendor fee. Thirdweb/Openfort
# remain as swappable adapters behind the WalletService abstraction but are
# unused by default.
WALLET_PROVIDER=lisk
THIRDWEB_ENGINE_URL=
THIRDWEB_ACCESS_TOKEN=
THIRDWEB_BACKEND_WALLET_ADDRESS=
THIRDWEB_DEFAULT_CHAIN=lisk
THIRDWEB_USDC_CONTRACT_ADDRESS=
OPENFORT_API_URL=
OPENFORT_SECRET_KEY=

# sendam-ai: deployed intent-decoding microservice (POST /decode) used to
# parse "send" requests from free-form chat text (English/Pidgin/Yoruba/
# Igbo/Hausa, plus "5k"/"1.5m" shorthand). Requests are HMAC-SHA256 signed
# over the raw JSON body — SENDAM_AI_SIGNING_SECRET must match the
# SERVICE_SIGNING_SECRET configured on the sendam-ai deployment itself.
# Without a valid secret here, SEND intent detection silently falls back to
# the generic help message (decode() throws, caught and logged).
SENDAM_AI_BASE_URL=https://intent-decoder.onrender.com
SENDAM_AI_SIGNING_SECRET=
# Per-request timeout. sendam-ai runs on Render's free tier, which spins
# down after ~15 min idle; a cold start can take 10s+. Default (30000)
# covers that, and sendamAi.client.js retries once on a timeout so a cold
# start on the first attempt doesn't fail the request outright.
SENDAM_AI_TIMEOUT_MS=30000

# Passkey (WebAuthn) enrollment during onboarding. rpID is the exact domain
# (no scheme/port) and origin is the exact scheme+domain+port apps/landing is
# served from — a mismatch hard-fails every ceremony client-side. Override
# both for local dev (e.g. WEBAUTHN_RP_ID=localhost).
WEBAUTHN_RP_ID=send-am-web.vercel.app
WEBAUTHN_ORIGIN=https://send-am-web.vercel.app

# Lisk is the primary settlement layer. Stellar is reserved for cross-border
# corridors selected by the Payment Orchestrator.
LISK_CHAIN_ID=lisk
LISK_RPC_URL=
LISK_ESCROW_CONTRACT_ADDRESS=
LISK_USDC_CONTRACT_ADDRESS=
LISK_EXPLORER_BASE_URL=
# A funded, self-custodied Wallet row that pays sendam-paymaster-planned gas
# top-ups into user wallets before an on-chain send (see gasTopup.js).
LISK_GAS_WALLET_ADDRESS=

# sendam-paymaster: private HTTP microservice that plans (never submits) gas
# top-ups for self-custodied Lisk wallets. Requests are HMAC-SHA256 signed
# over the raw JSON body, same contract as sendam-ai — PAYMASTER_SIGNING_SECRET
# must match SERVICE_SIGNING_SECRET on the sendam-paymaster deployment.
PAYMASTER_BASE_URL=
PAYMASTER_SIGNING_SECRET=
PAYMASTER_TIMEOUT_MS=15000

# sendam-settlement: private HTTP microservice — internal double-entry
# ledger, fee quoting, and treasury bookkeeping (not on-chain balances).
# Requests are HMAC-SHA256 signed over the raw JSON body, same contract as
# sendam-ai — SETTLEMENT_SIGNING_SECRET must match SERVICE_SIGNING_SECRET on
# the sendam-settlement deployment.
SETTLEMENT_BASE_URL=
SETTLEMENT_SIGNING_SECRET=
SETTLEMENT_TIMEOUT_MS=15000
# Ledger account fee revenue from executed sends is recorded against, purely
# for internal reconciliation.
SETTLEMENT_TREASURY_USER_ID=treasury

# Pricing and FX.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
EXCHANGERATE_API_KEY=

# Fiat on/off ramp providers.
YELLOW_CARD_API_URL=
YELLOW_CARD_API_KEY=
PAYCHANT_API_URL=
PAYCHANT_API_KEY=

# KYC, AML, and PIN verification.
KYC_PROVIDER=smileid
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=
DOJAH_APP_ID=
DOJAH_SECRET_KEY=
PIN_PEPPER=
TIER_1_DAILY_LIMIT=50000
TIER_1_SINGLE_LIMIT=20000
TIER_2_DAILY_LIMIT=500000
TIER_2_SINGLE_LIMIT=200000
TIER_3_DAILY_LIMIT=5000000
TIER_3_SINGLE_LIMIT=1000000

# Voice payments.
VOICE_PROVIDER=deepgram
DEEPGRAM_API_KEY=
WHISPER_API_KEY=
OPENAI_API_KEY=

# Cloudflare R2 for media/receipt storage.
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
