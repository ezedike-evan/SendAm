PORT=3002
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST/sendam?sslmode=require
# Comma-separated origins allowed to call the REST API (admin + landing apps).
# Required in production; when empty in dev, all origins are allowed.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# 64-char hex (32 bytes). Generate your own — never reuse this placeholder.
# Used for aes-256-gcm encryption of wallet secret keys.
# openssl rand -hex 32
ENCRYPTION_KEY=
# Admin dashboard auth. ADMIN_PASSWORD is the login password; JWT_SECRET signs
# session tokens (use a long random value: openssl rand -hex 32). Both are
# required — the API will not start without them.
ADMIN_PASSWORD=
JWT_SECRET=
# Optional: admin session lifetime in hours (default 12).
ADMIN_SESSION_TTL_HOURS=12
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token
# Meta App Secret — verifies the X-Hub-Signature-256 header on webhook POSTs.
# Required in production; without it, forged webhook events are rejected.
WHATSAPP_APP_SECRET=
# Per-user transfer guardrails (XLM). Defaults: 1000 / 5000 / 50.
MAX_SEND_AMOUNT=1000
DAILY_SEND_LIMIT=5000
MAX_SENDS_PER_DAY=50
# Request rate limits (PostgreSQL-backed, shared across instances).
# REST API: max requests per IP per window. WhatsApp bot: max messages per
# sender per window.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
BOT_RATE_WINDOW_SEC=60
BOT_RATE_MAX=20
REDIS_URL=
UPSTASH_REDIS_URL=
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# The REST wallet API (/api/wallet/*) is unauthenticated — the phone number in
# the request body is the only identity. It's disabled in production unless you
# set this to "true". Outside production it defaults to enabled for local tests.
ENABLE_WALLET_REST_API=false
# Paymaster (optional) — a privately-run relayer that sponsors Lisk gas fees.
# Not part of this repo. Leaving both unset simply disables sponsorship; Lisk
# sends still work self-funded either way. Not yet wired into the live send
# flow — see paymaster.service.js.
PAYMASTER_SERVICE_URL=
PAYMASTER_API_KEY=
# NGN price display (src/services/priceOracle.service.js) — shows balances in
# Naira alongside the native asset. Swappable: official CBN vs. parallel-market
# rate is a product decision, not resolved here. Default provider
# (open.er-api.com) needs no API key; FX_API_KEY is only used if you swap in a
# provider that requires one.
FX_PROVIDER=exchangerate_api
FX_API_KEY=

# Wallet-as-a-Service. Use Thirdweb Engine by default; Openfort can be swapped
# behind the WalletService abstraction.
WALLET_PROVIDER=thirdweb
THIRDWEB_ENGINE_URL=
THIRDWEB_ACCESS_TOKEN=
THIRDWEB_BACKEND_WALLET_ADDRESS=
THIRDWEB_DEFAULT_CHAIN=lisk
THIRDWEB_USDC_CONTRACT_ADDRESS=
OPENFORT_API_URL=
OPENFORT_SECRET_KEY=

# Lisk is the primary settlement layer. Stellar is reserved for cross-border
# corridors selected by the Payment Orchestrator.
LISK_CHAIN_ID=lisk
LISK_RPC_URL=
LISK_ESCROW_CONTRACT_ADDRESS=

# Pricing and FX.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
EXCHANGERATE_API_KEY=

# Fiat on/off ramp providers.
YELLOW_CARD_API_URL=
YELLOW_CARD_API_KEY=
PAYCHANT_API_URL=
PAYCHANT_API_KEY=

# KYC, AML, and PIN verification.
KYC_PROVIDER=smileid
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=
DOJAH_APP_ID=
DOJAH_SECRET_KEY=
PIN_PEPPER=
TIER_1_DAILY_LIMIT=50000
TIER_1_SINGLE_LIMIT=20000
TIER_2_DAILY_LIMIT=500000
TIER_2_SINGLE_LIMIT=200000
TIER_3_DAILY_LIMIT=5000000
TIER_3_SINGLE_LIMIT=1000000

# Voice payments.
VOICE_PROVIDER=deepgram
DEEPGRAM_API_KEY=
WHISPER_API_KEY=
OPENAI_API_KEY=

# Cloudflare R2 for media/receipt storage.
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
