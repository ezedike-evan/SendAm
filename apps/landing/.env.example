# URL of the admin dashboard app (used by header/footer links).
# Keep localhost in development. In production, set this to the admin subdomain,
# for example: https://admin.your-domain.com
VITE_ADMIN_URL=http://localhost:3001

# WhatsApp Business number for the "Start on WhatsApp" CTA, digits only with
# country code and no +, e.g. 2348012345678. Leave empty in dev to let WhatsApp
# pick the chat. Set this in production to deep-link straight to the SendAm bot.
VITE_WHATSAPP_NUMBER=
